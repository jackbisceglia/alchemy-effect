{
  "extends": "../../tsconfig.base.json",
  "include": ["package.json", "test"],
  "exclude": [
    "test/Local/fixtures/rpc-server-entry.ts",
    "test/Local/fixtures/rpc-spawner-parent.ts",
    "test/Local/fixtures/rpc-spawner-devserver-parent.ts",
    // Standalone wrangler + @cloudflare/containers control harness — it imports
    // `cloudflare:workers` (via @cloudflare/containers) and uses Workers runtime
    // globals that only resolve under wrangler's bundler, not plain tsc. It is
    // deployed/run on its own (`wrangler deploy` + `bun bench.ts`), never
    // imported by the vitest suite.
    "test/Cloudflare/Container/fixtures/benchmark/wrangler/**"
  ],
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "outDir": "./lib",
    "rootDir": ".",
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "target": "ESNext",
    "paths": {
      "@/*": ["./src/*"]
    },
    // Solid is the default JSX runtime in this package; React files opt in per-file.
    "jsx": "react-jsx",
    "jsxImportSource": "@opentui/solid",
    "lib": ["DOM", "DOM.Iterable", "ES2023"]
  },
  "references": [
    {
      "path": "./tsconfig.json"
    },
    {
      "path": "./tsconfig.bin.json"
    }
  ]
}
